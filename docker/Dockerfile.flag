FROM golang:1.26-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /flag-service ./cmd/flag-service

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /flag-service /flag-service
EXPOSE 50052
CMD ["/flag-service"]
